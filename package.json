{
  "name": "alphalint",
  "version": "0.1.0",
  "description": "Fast, multi-language code linter powered by tree-sitter",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "alphalint": "src/cli.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "lint": "node src/cli.js check ."
  },
  "dependencies": {
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.24.7"
  },
  "keywords": [
    "linter",
    "static-analysis",
    "tree-sitter",
    "multi-language"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/h4ckmp/alphalint.git"
  },
  "homepage": "https://github.com/h4ckmp/alphalint#readme",
  "engines": {
    "node": ">=18"
  }
}
